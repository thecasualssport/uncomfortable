# Copy this file to .env and fill in real values. Never commit .env.
#
# LOCAL DEV vs PRODUCTION — the values below are for local dev (localhost:5050).
# When deploying to a real host, set these as environment variables in the
# host's dashboard instead of a committed file, using the production values
# noted inline below.

# From Google Cloud Console > APIs & Services > Credentials > OAuth client ID (Web application)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Must exactly match an "Authorized redirect URI" on that OAuth client.
# Production: https://www.uncomfortablecalendar.com/api/auth/google/callback
# (also add that as a new redirect URI in Google Cloud Console — it doesn't replace localhost, add both)
GOOGLE_REDIRECT_URI=http://localhost:5050/api/auth/google/callback

# Where the server sends the browser back to after login / Stripe checkout.
# Production: https://www.uncomfortablecalendar.com/
# SESSION_COOKIE_SECURE is derived from this — must start with https:// in production
# or login sessions won't work (browsers drop Secure cookies over plain http).
FRONTEND_URL=http://localhost:5050/

# Random string used to sign session cookies. Generate one with:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
# Use a DIFFERENT value in production than local dev.
SECRET_KEY=

# 5000 is macOS's AirPlay Receiver port on modern Macs — avoid it, hence 5050 here.
# Most hosts (Render/Railway/etc.) inject their own PORT — leave this unset there.
PORT=5050

# Local dev convenience only (autoreload + interactive debugger). NEVER set this
# to 1 in production — Flask's debugger allows remote code execution if reachable.
# Irrelevant when served via gunicorn (see Procfile) since that never hits this flag.
FLASK_DEBUG=1

# Optional: absolute path to the SQLite file. Defaults to a file next to server.py,
# which is fine locally but usually WRONG in production — most hosts wipe local
# disk on every deploy. Point this at a persistent volume's mount path instead,
# e.g. /var/data/data.db, and make sure that volume is actually configured on the host.
DATABASE_PATH=

# From the Stripe Dashboard > Developers > API keys.
# sk_test_/pk_test_ for test mode, sk_live_/pk_live_ for real charges.
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=

# Dashboard > Product catalog > your recurring Price > Price ID (starts with "price_")
STRIPE_PRICE_ID=

# Dashboard > Developers > Webhooks > your endpoint > Signing secret (starts with "whsec_").
# Only usable once this app has a public HTTPS URL — webhooks can't reach localhost.
# Production endpoint URL: https://www.uncomfortablecalendar.com/api/billing/webhook
STRIPE_WEBHOOK_SECRET=
